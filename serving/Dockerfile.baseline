FROM python:3.10-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir fastapi==0.111.0 uvicorn==0.30.1 \
    transformers==4.41.2 torch==2.3.0 pydantic==2.7.1

# Download the model at build time so it is cached in the image
RUN python -c "from transformers import pipeline; \
    pipeline('text-classification', model='distilbert-base-uncased')"

COPY app_baseline.py .

EXPOSE 8000
CMD ["uvicorn", "app_baseline:app", "--host", "0.0.0.0", "--port", "8000"]
